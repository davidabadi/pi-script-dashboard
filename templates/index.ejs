<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Script Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/monaco-editor@0.40.0/min/vs/loader.js"></script>
</head>
<body class="bg-gray-900 text-gray-100 font-sans">
  <div class="max-w-6xl mx-auto p-6">
    <header class="bg-gray-800 rounded shadow mb-6 px-4 py-4 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
      <h1 class="text-2xl font-bold">📋 Script Dashboard</h1>
      <div class="flex gap-3">
        <a href="/new" class="bg-green-600 hover:bg-green-700 text-white font-semibold py-2 px-4 rounded text-center">➕ New Script</a>
        <button id="update-button"
          class="bg-purple-600 hover:bg-purple-700 text-white font-semibold py-2 px-4 rounded"
          onclick="runUpdate()" type="button">
          🔄 Update Dashboard
        </button>
        <a href="/logout" class="bg-red-600 hover:bg-red-700 text-white font-semibold py-2 px-4 rounded text-center">
          Logout
        </a>
      </div>
    </header>

    <% if (messages && messages.length) { %>
      <% messages.forEach(msg => { %>
        <div class="mb-4 p-3 rounded <%= msg.category === 'success' ? 'bg-green-900 text-green-200' : 'bg-red-900 text-red-200' %>">
          <%= msg.text %>
        </div>
      <% }) %>
    <% } %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
      <% for (const name in scripts) { %>
      <div class="p-4 bg-gray-800 rounded shadow">
        <h2 class="text-xl font-semibold mb-3 flex justify-between items-center">
          <%= name %>
          <% if (status[name]) { %>
            <% if (status[name] === 'running') { %>
              <span class="text-xs px-2 py-1 rounded bg-blue-200 text-blue-800">Running</span>
            <% } else { %>
              <span class="text-xs px-2 py-1 rounded <%= status[name] === 'success' ? 'bg-green-200 text-green-800' : 'bg-red-200 text-red-800' %>">
                <%= status[name] === 'success' ? 'Success' : 'Failed' %>
              </span>
            <% } %>
          <% } %>
        </h2>
        <div class="flex flex-wrap gap-2">
          <a href="/run/<%= encodeURIComponent(name) %>" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">▶ Run</a>
          <a href="/log/<%= encodeURIComponent(name) %>" class="px-4 py-2 bg-gray-700 text-white rounded hover:bg-gray-800">📄 View Log</a>
          <a href="/toggle_cron/<%= encodeURIComponent(name) %>"
             class="px-4 py-2 <%= paused[name] ? 'bg-green-600 hover:bg-green-700' : 'bg-yellow-500 hover:bg-yellow-600' %> text-white rounded">
             <%= paused[name] ? '▶ Resume' : '⏸ Pause' %>
          </a>
          <a href="/edit/<%= encodeURIComponent(name) %>" class="px-4 py-2 bg-purple-600 text-white rounded hover:bg-purple-700">✏ Edit</a>
        </div>
      </div>
      <% } %>
    </div>

    <details class="bg-gray-800 rounded shadow p-4">
      <summary class="text-xl font-semibold cursor-pointer select-none">🕒 Current Cron Jobs</summary>
      <div id="cron-editor" class="mt-2 border border-gray-600 rounded" style="height:300px;"></div>
    </details>

    <details class="bg-gray-800 rounded shadow p-4 mt-6">
      <summary class="text-xl font-semibold cursor-pointer select-none">💾 Drive Usage</summary>
      <table class="mt-2 w-full text-left">
        <thead>
          <tr>
            <th class="px-2 py-1">Mount</th>
            <th class="px-2 py-1">Used</th>
            <th class="px-2 py-1">Total</th>
            <th class="px-2 py-1">Usage</th>
          </tr>
        </thead>
        <tbody>
          <% drives.forEach(d => { %>
          <tr>
            <td class="px-2 py-1"><%= d.target %> (<%= d.source %>)</td>
            <td class="px-2 py-1"><%= d.used %></td>
            <td class="px-2 py-1"><%= d.size %></td>
            <td class="px-2 py-1"><%= d.percent %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </details>
  </div>

  <script>
    async function runUpdate() {
      const button = document.getElementById("update-button");
      button.disabled = true;
      button.innerText = "🔄 Updating...";

      await fetch("/update", { method: "POST" });

      const checkInterval = setInterval(async () => {
        const res = await fetch("/update-status");
        const data = await res.json();
        if (!data.updating) {
          clearInterval(checkInterval);
          button.innerText = "✅ Updated – Click to reload";
          button.disabled = false;
          button.onclick = () => location.reload();
        }
      }, 2000);
    }
    require.config({ paths: { vs: 'https://cdn.jsdelivr.net/npm/monaco-editor@0.40.0/min/vs' } });
    require(['vs/editor/editor.main'], function () {
      monaco.editor.create(document.getElementById('cron-editor'), {
        value: <%- JSON.stringify(cron_output) %>,
        language: 'shell',
        readOnly: true,
        automaticLayout: true,
        theme: 'vs-dark',
      });
    });
  </script>
</body>
</html>
