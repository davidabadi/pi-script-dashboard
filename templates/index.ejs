<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Script Dashboard</title>
  <link rel="stylesheet" href="/tailwind.css" />
  <script src="https://cdn.jsdelivr.net/npm/monaco-editor@0.40.0/min/vs/loader.js"></script>
</head>
<body class="bg-neutral-950 text-neutral-100 font-sans">
  <div class="max-w-6xl mx-auto p-6">
    <header class="bg-neutral-900 border border-neutral-700 rounded shadow mb-6 px-4 py-4 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
      <h1 class="text-2xl font-bold">📋 Script Dashboard</h1>
      <div class="flex gap-3">
        <a href="/new" class="bg-sky-600 hover:bg-sky-700 text-white font-semibold py-2 px-4 rounded text-center">➕ New Script</a>
        <button id="update-button"
          class="bg-teal-600 hover:bg-teal-700 text-white font-semibold py-2 px-4 rounded"
          onclick="runUpdate()" type="button">
          🔄 Update Dashboard
        </button>
        <a href="/logout" class="bg-rose-600 hover:bg-rose-700 text-white font-semibold py-2 px-4 rounded text-center">
          Logout
        </a>
      </div>
    </header>

    <% if (messages && messages.length) { %>
      <% messages.forEach(msg => { %>
        <div class="mb-4 p-3 rounded <%= msg.category === 'success' ? 'bg-neutral-800 text-green-300' : 'bg-neutral-800 text-rose-300' %>">
          <%= msg.text %>
        </div>
      <% }) %>
    <% } %>

    <div id="scripts-list" class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
      <% scriptOrder.forEach(name => { %>
      <div class="p-4 bg-neutral-900 border border-neutral-700 rounded shadow" data-name="<%= name %>">
        <h2 class="text-xl font-semibold mb-3 flex justify-between items-center cursor-move select-none" draggable="true">
          <%= name %>
          <% if (status[name]) { %>
            <% if (status[name] === 'running') { %>
              <span class="text-xs px-2 py-1 rounded bg-sky-200 text-sky-800">Running</span>
            <% } else { %>
              <span class="text-xs px-2 py-1 rounded <%= status[name] === 'success' ? 'bg-green-200 text-green-800' : 'bg-rose-200 text-rose-800' %>">
                <%= status[name] === 'success' ? 'Success' : 'Failed' %>
              </span>
            <% } %>
          <% } %>
        </h2>
        <p class="text-sm text-neutral-300 mb-2">Last run: <%= last_run[name] || 'Never' %></p>
        <div class="flex flex-wrap gap-2">
          <a href="/run/<%= encodeURIComponent(name) %>" class="px-4 py-2 bg-sky-600 text-white rounded hover:bg-sky-700">▶ Run</a>
          <a href="/log/<%= encodeURIComponent(name) %>" class="px-4 py-2 bg-neutral-700 text-white rounded hover:bg-neutral-600">📄 View Log</a>
          <a href="/toggle_cron/<%= encodeURIComponent(name) %>"
             class="px-4 py-2 <%= paused[name] ? 'bg-teal-600 hover:bg-teal-700' : 'bg-yellow-600 hover:bg-yellow-700' %> text-white rounded">
             <%= paused[name] ? '▶ Resume' : '⏸ Pause' %>
          </a>
          <a href="/edit/<%= encodeURIComponent(name) %>" class="px-4 py-2 bg-purple-600 text-white rounded hover:bg-purple-700">✏ Edit</a>
        </div>
      </div>
      <% }) %>
    </div>

    <details class="bg-neutral-900 border border-neutral-700 rounded shadow p-4">
      <summary class="text-xl font-semibold cursor-pointer select-none">🕒 Current Cron Jobs</summary>
      <div id="cron-editor" class="mt-2 border border-neutral-700 rounded" style="height:300px;"></div>
    </details>

  </div>

  <script>
    async function runUpdate() {
      const button = document.getElementById("update-button");
      button.disabled = true;
      button.innerText = "🔄 Updating...";

      await fetch("/update", { method: "POST" });

      const checkInterval = setInterval(async () => {
        const res = await fetch("/update-status");
        const data = await res.json();
        if (!data.updating) {
          clearInterval(checkInterval);
          button.innerText = "✅ Updated – Click to reload";
          button.disabled = false;
          button.onclick = () => location.reload();
        }
      }, 2000);
    }
    require.config({
      paths: {
        vs: 'https://cdn.jsdelivr.net/npm/monaco-editor@0.40.0/min/vs',
        sortablejs: 'https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min'
      }
    });
    require(['vs/editor/editor.main', 'sortablejs'], function (_, Sortable) {
      monaco.editor.create(document.getElementById('cron-editor'), {
        value: <%- JSON.stringify(cron_output) %>,
        language: 'shell',
        readOnly: true,
        automaticLayout: true,
        theme: 'vs-dark',
      });
      const el = document.getElementById('scripts-list');
      if (el) {
        Sortable.create(el, {
          animation: 150,
          handle: 'h2',
          onEnd: async () => {
            const order = Array.from(el.children).map((c) => c.dataset.name);
            await fetch('/reorder', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ order }),
            });
          },
        });
      }
    });
  </script>
</body>
</html>
