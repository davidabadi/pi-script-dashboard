<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= isNew ? 'Add Script' : 'Edit Script' %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/monaco-editor@0.40.0/min/vs/loader.js"></script>
</head>
<body class="bg-gray-900 text-gray-100 font-sans h-screen p-4">
  <div class="bg-gray-800 p-4 rounded shadow flex flex-col mb-4">
    <h1 class="text-xl font-bold mb-4"><%= isNew ? '➕ Add Script' : '✏️ Edit Script' %></h1>
    <% if (messages && messages.length) { %>
      <% messages.forEach(msg => { %>
        <div class="mb-4 p-3 rounded <%= msg.category === 'success' ? 'bg-green-900 text-green-200' : 'bg-red-900 text-red-200' %>"><%= msg.text %></div>
      <% }) %>
    <% } %>
    <form method="POST" class="flex flex-col">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block mb-1 text-sm font-semibold">Script Name</label>
          <input type="text" name="name" value="<%= data.name %>" required class="w-full px-3 py-1 border border-gray-600 rounded bg-gray-700" />
        </div>
        <div>
          <label class="block mb-1 text-sm font-semibold">Script Full Path</label>
          <input type="text" name="script" value="<%= data.script %>" required class="w-full px-3 py-1 border border-gray-600 rounded bg-gray-700" />
        </div>
        <div>
          <label class="block mb-1 text-sm font-semibold">Log File</label>
          <input type="text" name="log" value="<%= data.log %>" required class="w-full px-3 py-1 border border-gray-600 rounded bg-gray-700" />
        </div>
        <div>
          <label class="block mb-1 text-sm font-semibold">Cron Job Tag</label>
          <input type="text" name="cron_tag" value="<%= data.cron_tag %>" required class="w-full px-3 py-1 border border-gray-600 rounded bg-gray-700" />
        </div>
        <div>
          <label class="block mb-1 text-sm font-semibold">Lock File</label>
          <input type="text" name="lock" value="<%= data.lock %>" required class="w-full px-3 py-1 border border-gray-600 rounded bg-gray-700" />
        </div>
        <div>
          <label class="block mb-1 text-sm font-semibold">Cron Job Timer</label>
          <input type="text" name="timer" value="<%= data.timer %>" required class="w-full px-3 py-1 border border-gray-600 rounded bg-gray-700" />
        </div>
      </div>
      <input type="hidden" name="content" id="hidden-content" />
      <div id="editor" class="border border-gray-600 rounded mb-4 w-full" style="height:90vh;"></div>
      <div class="flex gap-3">
        <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded">Save</button>
        <a href="/" class="px-4 py-2 bg-gray-600 rounded hover:bg-gray-700">Cancel</a>
      </div>
    </form>
  </div>
  <script>
    require.config({ paths: { vs: 'https://cdn.jsdelivr.net/npm/monaco-editor@0.40.0/min/vs' } });
    require(['vs/editor/editor.main'], function () {
      const editor = monaco.editor.create(document.getElementById('editor'), {
        value: <%- JSON.stringify(data.content) %>,
        language: 'shell',
        automaticLayout: true,
        theme: 'vs-dark',
      });
      document.querySelector('form').addEventListener('submit', () => {
        document.getElementById('hidden-content').value = editor.getValue();
      });
    });
  </script>
</body>
</html>
