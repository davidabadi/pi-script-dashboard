<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="color-scheme" content="light dark" />
  <title><%= isNew ? 'Add Script' : 'Edit Script' %> - Pi Script Dashboard</title>
  <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <link rel="stylesheet" href="/tailwind.css?v=<%= cacheBust %>" />
  <script src="https://cdn.jsdelivr.net/npm/monaco-editor@0.40.0/min/vs/loader.js"></script>
</head>
<body class="app-shell">
  <div class="mx-auto flex min-h-screen w-full max-w-7xl flex-col gap-6 px-4 py-6 sm:px-6 lg:px-8">
    <header class="glass-panel rounded-[2rem] px-5 py-5 sm:px-7 lg:px-8">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl space-y-4">
          <div class="flex items-center gap-4">
            <img src="/favicon.svg" alt="" class="h-14 w-14 flex-none rounded-[1.4rem] shadow-lg shadow-brand-500/20" />
            <div>
              <p class="text-xs uppercase tracking-[0.24em] text-slate-500 dark:text-slate-400">Authoring workspace</p>
              <h1 class="mt-1 text-3xl font-semibold tracking-[-0.04em] text-slate-950 dark:text-white"><%= isNew ? 'Script composer' : 'Script editor' %></h1>
            </div>
          </div>
          <p class="max-w-2xl text-sm leading-6 text-slate-600 dark:text-slate-300"><%= isNew ? 'Register a new automation job with executable path, schedule, logs, and optional config.' : 'Refine script content, cron behavior, and file paths without leaving the editing surface.' %></p>
        </div>
        <div class="flex items-center justify-start">
          <a href="/" class="inline-flex cursor-pointer items-center justify-center rounded-2xl border border-slate-200/80 bg-white/80 px-4 py-3 text-sm font-semibold text-slate-700 transition hover:border-brand-200 hover:text-brand-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-500 dark:border-slate-700 dark:bg-slate-900/70 dark:text-slate-200 dark:hover:border-brand-500/30 dark:hover:text-brand-200 motion-reduce:transition-none">Back to dashboard</a>
        </div>
      </div>
    </header>

    <% if (messages && messages.length) { %>
      <div class="space-y-3" role="status">
        <% messages.forEach(msg => { %>
          <div class="glass-panel rounded-2xl px-4 py-3 text-sm font-medium <%= msg.category === 'success' ? 'border-emerald-200/80 text-emerald-700 dark:border-emerald-500/30 dark:text-emerald-200' : 'border-rose-200/80 text-rose-700 dark:border-rose-500/30 dark:text-rose-200' %>"><%= msg.text %></div>
        <% }) %>
      </div>
    <% } %>

    <section class="glass-panel rounded-[2rem] px-5 py-5 sm:px-6 lg:px-7" aria-labelledby="script-form-heading">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-xs uppercase tracking-[0.24em] text-slate-500 dark:text-slate-400">Metadata and source</p>
          <h2 id="script-form-heading" class="mt-2 text-2xl font-semibold tracking-[-0.04em] text-slate-950 dark:text-white"><%= isNew ? 'Script metadata' : 'Update script details' %></h2>
          <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300">Provide executable paths, log locations, cron configuration, and the script body.</p>
        </div>
      </div>

      <form method="POST" class="mt-6 space-y-6">
        <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-5">
          <div class="space-y-2">
            <label for="name" class="text-sm font-medium text-slate-700 dark:text-slate-200">Script name</label>
            <input id="name" type="text" name="name" value="<%= data.name %>" required class="w-full rounded-2xl border border-slate-200/80 bg-white/85 px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition placeholder:text-slate-400 focus:border-brand-300 focus:ring-2 focus:ring-brand-100 dark:border-slate-700 dark:bg-slate-950/60 dark:text-slate-100 dark:placeholder:text-slate-500 dark:focus:border-brand-500 dark:focus:ring-brand-500/20 motion-reduce:transition-none xl:col-span-1" />
          </div>
          <div class="space-y-2 xl:col-span-2">
            <label for="script" class="text-sm font-medium text-slate-700 dark:text-slate-200">Script full path</label>
            <input id="script" type="text" name="script" value="<%= data.script %>" required class="w-full rounded-2xl border border-slate-200/80 bg-white/85 px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition placeholder:text-slate-400 focus:border-brand-300 focus:ring-2 focus:ring-brand-100 dark:border-slate-700 dark:bg-slate-950/60 dark:text-slate-100 dark:placeholder:text-slate-500 dark:focus:border-brand-500 dark:focus:ring-brand-500/20 motion-reduce:transition-none" />
          </div>
          <div class="space-y-2 xl:col-span-2">
            <label for="log" class="text-sm font-medium text-slate-700 dark:text-slate-200">Log file path</label>
            <input id="log" type="text" name="log" value="<%= data.log %>" required class="w-full rounded-2xl border border-slate-200/80 bg-white/85 px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition placeholder:text-slate-400 focus:border-brand-300 focus:ring-2 focus:ring-brand-100 dark:border-slate-700 dark:bg-slate-950/60 dark:text-slate-100 dark:placeholder:text-slate-500 dark:focus:border-brand-500 dark:focus:ring-brand-500/20 motion-reduce:transition-none" />
          </div>
          <div class="space-y-2 xl:col-span-3">
            <label for="lock" class="text-sm font-medium text-slate-700 dark:text-slate-200">Lock file path</label>
            <input id="lock" type="text" name="lock" value="<%= data.lock %>" required class="w-full rounded-2xl border border-slate-200/80 bg-white/85 px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition placeholder:text-slate-400 focus:border-brand-300 focus:ring-2 focus:ring-brand-100 dark:border-slate-700 dark:bg-slate-950/60 dark:text-slate-100 dark:placeholder:text-slate-500 dark:focus:border-brand-500 dark:focus:ring-brand-500/20 motion-reduce:transition-none" />
          </div>
          <div class="space-y-2 xl:col-span-2">
            <label for="timer" class="text-sm font-medium text-slate-700 dark:text-slate-200">Cron schedule</label>
            <input id="timer" type="text" name="timer" value="<%= data.timer %>" required class="w-full rounded-2xl border border-slate-200/80 bg-white/85 px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition placeholder:text-slate-400 focus:border-brand-300 focus:ring-2 focus:ring-brand-100 dark:border-slate-700 dark:bg-slate-950/60 dark:text-slate-100 dark:placeholder:text-slate-500 dark:focus:border-brand-500 dark:focus:ring-brand-500/20 motion-reduce:transition-none" />
          </div>
        </div>

        <input type="hidden" name="content" id="hidden-content" />
        <input type="hidden" name="config_content" id="hidden-config-content" />
        <input type="hidden" name="config_enabled" id="config-enabled" value="<%= data.config_path ? 'true' : 'false' %>" />
        <div id="editor" class="editor-frame h-[60vh] rounded-[1.5rem]"></div>

        <div class="space-y-4 rounded-[1.75rem] border border-dashed border-slate-200/80 bg-white/40 p-4 dark:border-slate-700 dark:bg-slate-950/30">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div>
              <p class="text-sm font-semibold text-slate-950 dark:text-white">Config file</p>
              <p class="text-xs text-slate-500 dark:text-slate-400">Optional config input to reuse a shared script with different settings.</p>
            </div>
            <button type="button" id="config-toggle" class="inline-flex cursor-pointer items-center gap-2 rounded-full border border-slate-200/80 bg-white/80 px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-slate-600 transition hover:border-brand-200 hover:text-brand-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-500 dark:border-slate-700 dark:bg-slate-900/70 dark:text-slate-300 dark:hover:border-brand-500/30 dark:hover:text-brand-200 motion-reduce:transition-none" aria-pressed="<%= data.config_path ? 'true' : 'false' %>">
              <span id="config-toggle-label"><%= data.config_path ? 'Enabled' : 'Disabled' %></span>
            </button>
          </div>

          <div id="config-section" class="<%= data.config_path ? '' : 'hidden' %> space-y-4">
            <div class="space-y-2">
              <label for="config_path" class="text-sm font-medium text-slate-700 dark:text-slate-200">Config file path</label>
              <input id="config_path" type="text" name="config_path" value="<%= data.config_path %>" class="w-full rounded-2xl border border-slate-200/80 bg-white/85 px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition placeholder:text-slate-400 focus:border-brand-300 focus:ring-2 focus:ring-brand-100 dark:border-slate-700 dark:bg-slate-950/60 dark:text-slate-100 dark:placeholder:text-slate-500 dark:focus:border-brand-500 dark:focus:ring-brand-500/20 motion-reduce:transition-none" />
            </div>
            <div id="config-editor" class="editor-frame h-[40vh] rounded-[1.5rem]"></div>
            <div class="flex flex-col gap-3 sm:flex-row sm:justify-end">
              <button type="button" id="clear-config" class="inline-flex cursor-pointer items-center justify-center rounded-2xl border border-slate-200/80 bg-white/80 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-500 dark:border-slate-700 dark:bg-slate-950/60 dark:text-slate-200 dark:hover:border-slate-500 dark:hover:text-white motion-reduce:transition-none">Clear config</button>
              <% if (!isNew) { %>
                <button type="button" id="copy-config" class="inline-flex cursor-pointer items-center justify-center rounded-2xl border border-slate-200/80 bg-white/80 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-500 dark:border-slate-700 dark:bg-slate-950/60 dark:text-slate-200 dark:hover:border-slate-500 dark:hover:text-white motion-reduce:transition-none">Copy config</button>
              <% } %>
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row sm:justify-end">
          <button type="button" id="clear-script" class="inline-flex cursor-pointer items-center justify-center rounded-2xl border border-slate-200/80 bg-white/80 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-500 dark:border-slate-700 dark:bg-slate-950/60 dark:text-slate-200 dark:hover:border-slate-500 dark:hover:text-white motion-reduce:transition-none">Clear script</button>
          <% if (!isNew) { %>
            <button type="button" id="copy-script" class="inline-flex cursor-pointer items-center justify-center rounded-2xl border border-slate-200/80 bg-white/80 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-500 dark:border-slate-700 dark:bg-slate-950/60 dark:text-slate-200 dark:hover:border-slate-500 dark:hover:text-white motion-reduce:transition-none">Copy script</button>
          <% } %>
          <button type="submit" class="inline-flex cursor-pointer items-center justify-center rounded-2xl bg-brand-500 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-brand-500/20 transition hover:bg-brand-600 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-500 motion-reduce:transition-none">Save changes</button>
          <a href="/" class="inline-flex cursor-pointer items-center justify-center rounded-2xl border border-slate-200/80 bg-white/80 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-500 dark:border-slate-700 dark:bg-slate-950/60 dark:text-slate-200 dark:hover:border-slate-500 dark:hover:text-white motion-reduce:transition-none">Cancel</a>
        </div>
      </form>
    </section>
  </div>

  <script>
    require.config({ paths: { vs: 'https://cdn.jsdelivr.net/npm/monaco-editor@0.40.0/min/vs' } });
    require(['vs/editor/editor.main'], function () {
      const mql = window.matchMedia('(prefers-color-scheme: dark)');
      const currentTheme = () => (mql.matches ? 'vs-dark' : 'vs');
      const editor = monaco.editor.create(document.getElementById('editor'), {
        value: <%- JSON.stringify(data.content) %>,
        language: 'shell',
        automaticLayout: true,
        theme: currentTheme(),
        minimap: { enabled: false },
        fontFamily: "'Fira Code', 'Cascadia Code', 'Source Code Pro', 'Menlo', monospace"
      });
      const configEditor = monaco.editor.create(document.getElementById('config-editor'), {
        value: <%- JSON.stringify(data.config_content || '') %>,
        language: 'yaml',
        automaticLayout: true,
        theme: currentTheme(),
        minimap: { enabled: false },
        fontFamily: "'Fira Code', 'Cascadia Code', 'Source Code Pro', 'Menlo', monospace"
      });

      const applyTheme = () => monaco.editor.setTheme(currentTheme());
      applyTheme();
      if (mql.addEventListener) {
        mql.addEventListener('change', applyTheme);
      } else if (mql.addListener) {
        mql.addListener(applyTheme);
      }

      const form = document.querySelector('form');
      const clearButton = document.getElementById('clear-script');
      const copyButton = document.getElementById('copy-script');
      const clearConfigButton = document.getElementById('clear-config');
      const copyConfigButton = document.getElementById('copy-config');
      const configToggle = document.getElementById('config-toggle');
      const configToggleLabel = document.getElementById('config-toggle-label');
      const configSection = document.getElementById('config-section');
      const configPathField = document.getElementById('config_path');
      const configEnabledField = document.getElementById('config-enabled');
      const fields = [
        document.getElementById('name'),
        document.getElementById('script'),
        document.getElementById('log'),
        document.getElementById('lock'),
        document.getElementById('timer'),
        configPathField
      ];
      const getFormSnapshot = () => ({
        name: fields[0].value,
        script: fields[1].value,
        log: fields[2].value,
        lock: fields[3].value,
        timer: fields[4].value,
        content: editor.getValue(),
        config_path: fields[5].value,
        config_content: configEditor.getValue(),
        config_enabled: configEnabledField.value
      });
      const initialSnapshot = getFormSnapshot();
      let isDirty = false;
      const updateDirtyState = () => {
        const currentSnapshot = getFormSnapshot();
        isDirty = Object.keys(initialSnapshot).some((key) => currentSnapshot[key] !== initialSnapshot[key]);
      };

      fields.forEach((field) => field.addEventListener('input', updateDirtyState));
      editor.onDidChangeModelContent(updateDirtyState);
      configEditor.onDidChangeModelContent(updateDirtyState);

      window.addEventListener('beforeunload', (event) => {
        if (!isDirty) {
          return;
        }
        event.preventDefault();
        event.returnValue = 'You have unsaved changes.';
      });

      if (clearButton) {
        const resetClearLabel = () => {
          clearButton.textContent = 'Clear script';
          clearButton.disabled = false;
        };
        clearButton.addEventListener('click', () => {
          editor.setValue('');
          editor.focus();
          clearButton.textContent = 'Cleared!';
          clearButton.disabled = true;
          setTimeout(resetClearLabel, 2000);
        });
      }

      if (copyButton) {
        const resetCopyLabel = () => {
          copyButton.textContent = 'Copy script';
          copyButton.disabled = false;
        };
        copyButton.addEventListener('click', () => {
          const content = editor.getValue();
          copyButton.textContent = 'Copying...';
          copyButton.disabled = true;
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(content).then(() => {
              copyButton.textContent = 'Copied!';
              setTimeout(resetCopyLabel, 2000);
            }).catch(() => {
              resetCopyLabel();
              window.alert('Unable to copy script to clipboard.');
            });
            return;
          }

          const textarea = document.createElement('textarea');
          textarea.value = content;
          textarea.style.position = 'fixed';
          textarea.style.opacity = '0';
          document.body.appendChild(textarea);
          textarea.select();
          const copied = document.execCommand('copy');
          document.body.removeChild(textarea);
          if (copied) {
            copyButton.textContent = 'Copied!';
            setTimeout(resetCopyLabel, 2000);
          } else {
            resetCopyLabel();
            window.alert('Unable to copy script to clipboard.');
          }
        });
      }

      if (clearConfigButton) {
        const resetClearConfigLabel = () => {
          clearConfigButton.textContent = 'Clear config';
          clearConfigButton.disabled = false;
        };
        clearConfigButton.addEventListener('click', () => {
          configEditor.setValue('');
          configEditor.focus();
          clearConfigButton.textContent = 'Cleared!';
          clearConfigButton.disabled = true;
          setTimeout(resetClearConfigLabel, 2000);
        });
      }

      if (copyConfigButton) {
        const resetCopyConfigLabel = () => {
          copyConfigButton.textContent = 'Copy config';
          copyConfigButton.disabled = false;
        };
        copyConfigButton.addEventListener('click', () => {
          const content = configEditor.getValue();
          copyConfigButton.textContent = 'Copying...';
          copyConfigButton.disabled = true;
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(content).then(() => {
              copyConfigButton.textContent = 'Copied!';
              setTimeout(resetCopyConfigLabel, 2000);
            }).catch(() => {
              resetCopyConfigLabel();
              window.alert('Unable to copy config to clipboard.');
            });
            return;
          }

          const textarea = document.createElement('textarea');
          textarea.value = content;
          textarea.style.position = 'fixed';
          textarea.style.opacity = '0';
          document.body.appendChild(textarea);
          textarea.select();
          const copied = document.execCommand('copy');
          document.body.removeChild(textarea);
          if (copied) {
            copyConfigButton.textContent = 'Copied!';
            setTimeout(resetCopyConfigLabel, 2000);
          } else {
            resetCopyConfigLabel();
            window.alert('Unable to copy config to clipboard.');
          }
        });
      }

      if (configToggle) {
        const syncToggleState = (enabled) => {
          const isEnabled = Boolean(enabled);
          configToggle.setAttribute('aria-pressed', isEnabled ? 'true' : 'false');
          configToggleLabel.textContent = isEnabled ? 'Enabled' : 'Disabled';
          configEnabledField.value = isEnabled ? 'true' : 'false';
          if (isEnabled) {
            configSection.classList.remove('hidden');
            configEditor.layout();
          } else {
            configSection.classList.add('hidden');
          }
          updateDirtyState();
        };

        configToggle.addEventListener('click', () => {
          const nextState = configToggle.getAttribute('aria-pressed') !== 'true';
          syncToggleState(nextState);
        });

        syncToggleState(configToggle.getAttribute('aria-pressed') === 'true');
      }

      form.addEventListener('submit', () => {
        document.getElementById('hidden-content').value = editor.getValue();
        document.getElementById('hidden-config-content').value = configEditor.getValue();
        isDirty = false;
      });
    });
  </script>
</body>
</html>
