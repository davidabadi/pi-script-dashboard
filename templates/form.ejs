<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="color-scheme" content="light dark" />
  <title><%= isNew ? 'Add Script' : 'Edit Script' %> - Pi Script Dashboard</title>
  <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <link rel="stylesheet" href="/tailwind.css?v=<%= cacheBust %>" />
  <script src="https://cdn.jsdelivr.net/npm/monaco-editor@0.40.0/min/vs/loader.js"></script>
</head>
<body class="min-h-screen bg-gradient-to-br from-slate-100 via-slate-50 to-white text-slate-900 transition-colors dark:from-slate-950 dark:via-slate-900 dark:to-slate-950 dark:text-slate-100">
  <div class="mx-auto flex min-h-screen w-full max-w-5xl flex-col gap-8 px-4 py-10 sm:px-6 lg:px-10">
    <header class="flex flex-col gap-6 rounded-3xl bg-white/80 p-6 shadow-xl ring-1 ring-slate-200 backdrop-blur dark:bg-slate-900/70 dark:ring-slate-700 md:flex-row md:items-center md:justify-between">
      <div class="flex items-center gap-4">
        <span class="grid h-12 w-12 flex-none place-items-center rounded-2xl bg-gradient-to-br from-indigo-500 to-purple-500 text-sm font-semibold uppercase tracking-widest text-white">PS</span>
        <div class="space-y-1">
          <p class="text-2xl font-semibold tracking-tight"><%= isNew ? 'Script composer' : 'Script editor' %></p>
          <p class="text-sm text-slate-500 dark:text-slate-300"><%= isNew ? 'Register a new automation script and schedule.' : 'Update script details, schedule, and content.' %></p>
        </div>
      </div>
      <div class="flex items-center justify-start md:justify-end">
        <a href="/" class="inline-flex items-center justify-center rounded-xl border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-400 dark:border-slate-600 dark:text-slate-200 dark:hover:border-slate-500 dark:hover:text-white">Back to dashboard</a>
      </div>
    </header>

    <% if (messages && messages.length) { %>
      <div class="space-y-3" role="status">
        <% messages.forEach(msg => { %>
          <div class="rounded-2xl border px-4 py-3 text-sm font-medium shadow-sm <%= msg.category === 'success' ? 'border-emerald-200 bg-emerald-50 text-emerald-700 dark:border-emerald-500/40 dark:bg-emerald-500/10 dark:text-emerald-200' : 'border-rose-200 bg-rose-50 text-rose-700 dark:border-rose-500/40 dark:bg-rose-500/10 dark:text-rose-200' %>"><%= msg.text %></div>
        <% }) %>
      </div>
    <% } %>

    <section class="rounded-3xl border border-slate-200 bg-white/80 p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900/70" aria-labelledby="script-form-heading">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 id="script-form-heading" class="text-xl font-semibold tracking-tight text-slate-900 dark:text-slate-100"><%= isNew ? 'Script metadata' : 'Update script details' %></h2>
          <p class="text-sm text-slate-500 dark:text-slate-300">Provide executable paths, log locations, cron configuration, and the script body.</p>
        </div>
      </div>

      <form method="POST" class="mt-6 space-y-6">
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="space-y-2">
            <label for="name" class="text-sm font-medium text-slate-600 dark:text-slate-300">Script name</label>
            <input id="name" type="text" name="name" value="<%= data.name %>" required class="w-full rounded-xl border border-slate-200 bg-white/80 px-4 py-2 text-sm text-slate-900 shadow-sm outline-none transition placeholder:text-slate-400 focus:border-sky-500 focus:ring-2 focus:ring-sky-200 dark:border-slate-700 dark:bg-slate-900/60 dark:text-slate-100 dark:placeholder:text-slate-500 dark:focus:border-sky-400 dark:focus:ring-sky-500/30" />
          </div>
          <div class="space-y-2">
            <label for="script" class="text-sm font-medium text-slate-600 dark:text-slate-300">Script full path</label>
            <input id="script" type="text" name="script" value="<%= data.script %>" required class="w-full rounded-xl border border-slate-200 bg-white/80 px-4 py-2 text-sm text-slate-900 shadow-sm outline-none transition placeholder:text-slate-400 focus:border-sky-500 focus:ring-2 focus:ring-sky-200 dark:border-slate-700 dark:bg-slate-900/60 dark:text-slate-100 dark:placeholder:text-slate-500 dark:focus:border-sky-400 dark:focus:ring-sky-500/30" />
          </div>
          <div class="space-y-2">
            <label for="log" class="text-sm font-medium text-slate-600 dark:text-slate-300">Log file path</label>
            <input id="log" type="text" name="log" value="<%= data.log %>" required class="w-full rounded-xl border border-slate-200 bg-white/80 px-4 py-2 text-sm text-slate-900 shadow-sm outline-none transition placeholder:text-slate-400 focus:border-sky-500 focus:ring-2 focus:ring-sky-200 dark:border-slate-700 dark:bg-slate-900/60 dark:text-slate-100 dark:placeholder:text-slate-500 dark:focus:border-sky-400 dark:focus:ring-sky-500/30" />
          </div>
          <div class="space-y-2">
            <label for="lock" class="text-sm font-medium text-slate-600 dark:text-slate-300">Lock file path</label>
            <input id="lock" type="text" name="lock" value="<%= data.lock %>" required class="w-full rounded-xl border border-slate-200 bg-white/80 px-4 py-2 text-sm text-slate-900 shadow-sm outline-none transition placeholder:text-slate-400 focus:border-sky-500 focus:ring-2 focus:ring-sky-200 dark:border-slate-700 dark:bg-slate-900/60 dark:text-slate-100 dark:placeholder:text-slate-500 dark:focus:border-sky-400 dark:focus:ring-sky-500/30" />
          </div>
          <div class="space-y-2">
            <label for="timer" class="text-sm font-medium text-slate-600 dark:text-slate-300">Cron schedule</label>
            <input id="timer" type="text" name="timer" value="<%= data.timer %>" required class="w-full rounded-xl border border-slate-200 bg-white/80 px-4 py-2 text-sm text-slate-900 shadow-sm outline-none transition placeholder:text-slate-400 focus:border-sky-500 focus:ring-2 focus:ring-sky-200 dark:border-slate-700 dark:bg-slate-900/60 dark:text-slate-100 dark:placeholder:text-slate-500 dark:focus:border-sky-400 dark:focus:ring-sky-500/30" />
          </div>
        </div>

        <input type="hidden" name="content" id="hidden-content" />
        <input type="hidden" name="config_content" id="hidden-config-content" />
        <input type="hidden" name="config_enabled" id="config-enabled" value="<%= data.config_path ? 'true' : 'false' %>" />
        <div id="editor" class="h-[60vh] rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-950/70"></div>

        <div class="space-y-4 rounded-2xl border border-dashed border-slate-200 bg-slate-50/60 p-4 dark:border-slate-700 dark:bg-slate-950/40">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div>
              <p class="text-sm font-semibold text-slate-900 dark:text-slate-100">Config file</p>
              <p class="text-xs text-slate-500 dark:text-slate-400">Optional config input to reuse a shared script with different settings.</p>
            </div>
            <button type="button" id="config-toggle" class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-wide text-slate-600 transition hover:border-slate-300 hover:text-slate-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-400 dark:border-slate-600 dark:bg-slate-900/70 dark:text-slate-300 dark:hover:border-slate-500 dark:hover:text-white" aria-pressed="<%= data.config_path ? 'true' : 'false' %>">
              <span id="config-toggle-label"><%= data.config_path ? 'Enabled' : 'Disabled' %></span>
            </button>
          </div>

          <div id="config-section" class="<%= data.config_path ? '' : 'hidden' %> space-y-4">
            <div class="space-y-2">
              <label for="config_path" class="text-sm font-medium text-slate-600 dark:text-slate-300">Config file path</label>
              <input id="config_path" type="text" name="config_path" value="<%= data.config_path %>" class="w-full rounded-xl border border-slate-200 bg-white/80 px-4 py-2 text-sm text-slate-900 shadow-sm outline-none transition placeholder:text-slate-400 focus:border-sky-500 focus:ring-2 focus:ring-sky-200 dark:border-slate-700 dark:bg-slate-900/60 dark:text-slate-100 dark:placeholder:text-slate-500 dark:focus:border-sky-400 dark:focus:ring-sky-500/30" />
            </div>
            <div id="config-editor" class="h-[40vh] rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-950/70"></div>
          </div>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row sm:justify-end">
          <button type="button" id="clear-script" class="inline-flex items-center justify-center rounded-xl border border-slate-200 px-5 py-2.5 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-400 dark:border-slate-600 dark:text-slate-200 dark:hover:border-slate-500 dark:hover:text-white">Clear script</button>
          <% if (!isNew) { %>
            <button type="button" id="copy-script" class="inline-flex items-center justify-center rounded-xl border border-slate-200 px-5 py-2.5 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-400 dark:border-slate-600 dark:text-slate-200 dark:hover:border-slate-500 dark:hover:text-white">Copy script</button>
          <% } %>
          <button type="submit" class="inline-flex items-center justify-center rounded-xl bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-500">Save changes</button>
          <a href="/" class="inline-flex items-center justify-center rounded-xl border border-slate-200 px-5 py-2.5 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-400 dark:border-slate-600 dark:text-slate-200 dark:hover:border-slate-500 dark:hover:text-white">Cancel</a>
        </div>
      </form>
    </section>
  </div>

  <script>
    require.config({ paths: { vs: 'https://cdn.jsdelivr.net/npm/monaco-editor@0.40.0/min/vs' } });
    require(['vs/editor/editor.main'], function () {
      const mql = window.matchMedia('(prefers-color-scheme: dark)');
      const currentTheme = () => (mql.matches ? 'vs-dark' : 'vs');
      const editor = monaco.editor.create(document.getElementById('editor'), {
        value: <%- JSON.stringify(data.content) %>,
        language: 'shell',
        automaticLayout: true,
        theme: currentTheme(),
        minimap: { enabled: false },
        fontFamily: "'Fira Code', 'Cascadia Code', 'Source Code Pro', 'Menlo', 'monospace"
      });
      const configEditor = monaco.editor.create(document.getElementById('config-editor'), {
        value: <%- JSON.stringify(data.config_content || '') %>,
        language: 'yaml',
        automaticLayout: true,
        theme: currentTheme(),
        minimap: { enabled: false },
        fontFamily: "'Fira Code', 'Cascadia Code', 'Source Code Pro', 'Menlo', 'monospace"
      });

      const applyTheme = () => monaco.editor.setTheme(currentTheme());
      applyTheme();
      if (mql.addEventListener) {
        mql.addEventListener('change', applyTheme);
      } else if (mql.addListener) {
        mql.addListener(applyTheme);
      }

      const form = document.querySelector('form');
      const clearButton = document.getElementById('clear-script');
      const copyButton = document.getElementById('copy-script');
      const configToggle = document.getElementById('config-toggle');
      const configToggleLabel = document.getElementById('config-toggle-label');
      const configSection = document.getElementById('config-section');
      const configPathField = document.getElementById('config_path');
      const configEnabledField = document.getElementById('config-enabled');
      const fields = [
        document.getElementById('name'),
        document.getElementById('script'),
        document.getElementById('log'),
        document.getElementById('lock'),
        document.getElementById('timer'),
        configPathField
      ];
      const getFormSnapshot = () => ({
        name: fields[0].value,
        script: fields[1].value,
        log: fields[2].value,
        lock: fields[3].value,
        timer: fields[4].value,
        content: editor.getValue(),
        config_path: fields[5].value,
        config_content: configEditor.getValue(),
        config_enabled: configEnabledField.value
      });
      const initialSnapshot = getFormSnapshot();
      let isDirty = false;
      const updateDirtyState = () => {
        const currentSnapshot = getFormSnapshot();
        isDirty = Object.keys(initialSnapshot).some((key) => currentSnapshot[key] !== initialSnapshot[key]);
      };

      fields.forEach((field) => field.addEventListener('input', updateDirtyState));
      editor.onDidChangeModelContent(updateDirtyState);
      configEditor.onDidChangeModelContent(updateDirtyState);

      window.addEventListener('beforeunload', (event) => {
        if (!isDirty) {
          return;
        }
        event.preventDefault();
        event.returnValue = 'You have unsaved changes.';
      });

      if (clearButton) {
        const resetClearLabel = () => {
          clearButton.textContent = 'Clear script';
          clearButton.disabled = false;
        };
        clearButton.addEventListener('click', () => {
          editor.setValue('');
          editor.focus();
          clearButton.textContent = 'Cleared!';
          clearButton.disabled = true;
          setTimeout(resetClearLabel, 2000);
        });
      }

      if (copyButton) {
        const resetCopyLabel = () => {
          copyButton.textContent = 'Copy script';
          copyButton.disabled = false;
        };
        copyButton.addEventListener('click', () => {
          const content = editor.getValue();
          copyButton.textContent = 'Copying...';
          copyButton.disabled = true;
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(content).then(() => {
              copyButton.textContent = 'Copied!';
              setTimeout(resetCopyLabel, 2000);
            }).catch(() => {
              resetCopyLabel();
              window.alert('Unable to copy script to clipboard.');
            });
            return;
          }

          const textarea = document.createElement('textarea');
          textarea.value = content;
          textarea.style.position = 'fixed';
          textarea.style.opacity = '0';
          document.body.appendChild(textarea);
          textarea.select();
          const copied = document.execCommand('copy');
          document.body.removeChild(textarea);
          if (copied) {
            copyButton.textContent = 'Copied!';
            setTimeout(resetCopyLabel, 2000);
          } else {
            resetCopyLabel();
            window.alert('Unable to copy script to clipboard.');
          }
        });
      }

      if (configToggle) {
        const syncToggleState = (enabled) => {
          const isEnabled = Boolean(enabled);
          configToggle.setAttribute('aria-pressed', isEnabled ? 'true' : 'false');
          configToggleLabel.textContent = isEnabled ? 'Enabled' : 'Disabled';
          configEnabledField.value = isEnabled ? 'true' : 'false';
          if (isEnabled) {
            configSection.classList.remove('hidden');
            configEditor.layout();
          } else {
            configSection.classList.add('hidden');
          }
          updateDirtyState();
        };

        configToggle.addEventListener('click', () => {
          const nextState = configToggle.getAttribute('aria-pressed') !== 'true';
          syncToggleState(nextState);
        });

        syncToggleState(configToggle.getAttribute('aria-pressed') === 'true');
      }

      form.addEventListener('submit', () => {
        document.getElementById('hidden-content').value = editor.getValue();
        document.getElementById('hidden-config-content').value = configEditor.getValue();
        isDirty = false;
      });
    });
  </script>
</body>
</html>
