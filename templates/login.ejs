<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Login</title>
  <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <link rel="stylesheet" href="/tailwind.css" />
</head>
<body class="bg-neutral-950 flex items-center justify-center min-h-screen">
  <div class="bg-neutral-900 border border-neutral-700 text-white p-8 rounded shadow-md w-full max-w-md mx-4 sm:mx-0">
    <h2 class="text-xl font-bold mb-6 text-center">🔐 Dashboard Login</h2>
    <% if (messages && messages.length) { %>
      <% messages.forEach(msg => { %>
        <div class="mb-4 p-3 rounded bg-neutral-800 text-rose-300"><%= msg.text %></div>
      <% }) %>
    <% } %>
    <form method="POST">
      <div class="mb-4">
        <label for="username" class="block font-medium mb-1">Username</label>
        <input type="text" name="username" required class="w-full px-4 py-2 border border-neutral-700 rounded bg-neutral-800 text-white focus:outline-none focus:ring">
      </div>
      <div class="mb-6">
        <label for="password" class="block font-medium mb-1">Password</label>
        <input type="password" name="password" required class="w-full px-4 py-2 border border-neutral-700 rounded bg-neutral-800 text-white focus:outline-none focus:ring">
      </div>
      <button type="submit" class="w-full bg-sky-600 text-white py-2 rounded hover:bg-sky-700">Login</button>
    </form>
  </div>
</body>
</html>
