{
  "name": "pi-script-dashboard",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build:css": "tailwindcss -i ./tailwind.css -o ./public/tailwind.css --minify",
    "postinstall": "node -e \"if (process.platform !== 'linux') console.warn('⚠️ Skipping authenticate-pam on non-Linux platform.')\""
  },
  "dependencies": {
    "@tailwindcss/cli": "latest",
    "dotenv": "^16.0.3",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "session-file-store": "^1.5.0",
    "tailwindcss": "latest"
  },
  "optionalDependencies": {
    "authenticate-pam": "^1.0.5"
  }
}
