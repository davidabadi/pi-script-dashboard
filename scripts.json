{
  "Unraid Backup": {
    "script": "/usr/local/bin/backup_unraid.sh",
    "log": "/var/log/custom/backup_unraid.log",
    "cron_tag": "Unraid Backup",
    "lock": "/etc/backup_unraid.lock",
    "order": 3
  },
  "Unraid PostgreSQL Backup": {
    "script": "/usr/local/bin/backup_unraid_postgresql_db.sh",
    "log": "/var/log/custom/unraid_postgresql_db_backup.log",
    "cron_tag": "Unraid PostgreSQL Backup",
    "lock": "/etc/unraid_postgresql_db_backup.lock",
    "order": 2
  },
  "Update + Reboot": {
    "script": "/usr/local/bin/update_and_reboot.sh",
    "log": "/var/log/custom/update_and_reboot.log",
    "cron_tag": "Update + Reboot",
    "lock": "/etc/update_and_reboot.lock",
    "order": 4
  },
  "Conabadi Server Backup": {
    "script": "/usr/local/bin/backup_forge_server.sh",
    "log": "/var/log/custom/conabadi_server_backup.log",
    "cron_tag": "Conabadi Server Backup",
    "lock": "/etc/conabadi_server_backup.lock",
    "order": 1,
    "config_path": "/home/pi/backup-configs/conabadi.conf"
  },
  "Lazo Panama Server Backup": {
    "script": "/usr/local/bin/backup_forge_server.sh",
    "log": "/var/log/custom/lazopanama_server_backup.log",
    "cron_tag": "Lazo Panama Server Backup",
    "lock": "/etc/lazopanama_server_backup.lock",
    "order": 0,
    "config_path": "/home/pi/backup-configs/lazopanama.conf"
  }
}