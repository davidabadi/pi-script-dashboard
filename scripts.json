{
  "Conabadi MySQL Backup": {
    "script": "/usr/local/bin/backup_conabadi_db.sh",
    "log": "/var/log/custom/conabadi_db_backup.log",
    "cron_tag": "backup_conabadi_db.sh",
    "lock": "/etc/conabadi_db_backup.lock",
    "order": 0
  },
  "Update + Reboot": {
    "script": "/usr/local/bin/update_and_reboot.sh",
    "log": "/var/log/custom/update_and_reboot.log",
    "cron_tag": "update_and_reboot.sh",
    "lock": "/etc/update_and_reboot.lock",
    "order": 4
  },
  "Lazo Panama MySQL Backup": {
    "script": "/usr/local/bin/backup_lazopanama_db.sh",
    "log": "/var/log/custom/lazopanama_db_backup.log",
    "cron_tag": "backup_lazopanama_db.sh",
    "lock": "/etc/lazopanama_db_backup.lock",
    "order": 1
  },
  "Unraid PostgreSQL Backup": {
    "script": "/usr/local/bin/backup_unraid_postgresql_db.sh",
    "log": "/var/log/custom/unraid_postgresql_db_backup.log",
    "cron_tag": "backup_unraid_postgresql_db.sh",
    "lock": "/etc/unraid_postgresql_db_backup.lock",
    "order": 2
  },
  "Unraid Backup": {
    "script": "/usr/local/bin/backup_unraid.sh",
    "log": "/var/log/custom/backup_unraid.log",
    "cron_tag": "backup_unraid.sh",
    "lock": "/etc/backup_unraid.lock",
    "order": 3
  }
}